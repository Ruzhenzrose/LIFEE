# LIFEE 配置文件
# 复制此文件为 .env 并填入你的配置

# ============================================================
# LLM Provider 选择 (必填)
# 可选值: claude, synthetic, qwen-portal, qwen, gemini, ollama, opencode
# ============================================================
LLM_PROVIDER=claude

# ============================================================
# Claude API (需要 Claude 会员或 API Key)
# ============================================================
# 如果已登录 Claude Code CLI，可以不设置 API Key
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-5

# ============================================================
# Synthetic (免费大模型代理) ⭐⭐推荐
# 支持的模型: deepseek-v3, glm-4.7, qwen3-235b, kimi-k2 等
# 获取方式:
#   1. 使用 clawdbot 登录: npm install -g clawdbot
#   2. 或访问 https://synthetic.new/ 获取 API Key
# ============================================================
SYNTHETIC_MODEL=deepseek-v3
SYNTHETIC_API_KEY=

# ============================================================
# Qwen Portal (完全免费，通过 clawdbot OAuth 登录) ⭐推荐
# 使用方法:
#   1. npm install -g clawdbot
#   2. 运行 clawdbot 并登录 Qwen Portal
#   3. 设置 LLM_PROVIDER=qwen-portal
# ============================================================
QWEN_PORTAL_MODEL=coder-model

# ============================================================
# Qwen DashScope API (免费 2000 请求/天)
# 获取地址: https://dashscope.console.aliyun.com/
# ============================================================
QWEN_API_KEY=
QWEN_MODEL=qwen-plus

# ============================================================
# Google Gemini API
# 获取地址: https://aistudio.google.com/apikey
# ============================================================
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ============================================================
# Google Search API（可选，用于 /generate-personas 联网搜索）
# 不填则自动使用上面的 GOOGLE_API_KEY
# 单独申请好处：独立监控搜索用量 / 分开计费
# 获取地址: https://aistudio.google.com/apikey → 新建 key
# ============================================================
GOOGLE_SEARCH_API_KEY=

# ============================================================
# Ollama (本地运行，完全免费)
# 安装地址: https://ollama.ai/
# 使用前需要: ollama pull qwen2.5
# ============================================================
OLLAMA_MODEL=qwen2.5
OLLAMA_BASE_URL=http://localhost:11434/v1

# ============================================================
# OpenCode Zen (GLM-4.7 免费) ⭐推荐
# 使用 glm-4.7 模型完全免费，其他模型需要 $200/月订阅
# ============================================================
OPENCODE_API_KEY=
OPENCODE_MODEL=glm-4.7

# ============================================================
# OpenAI Embedding API (用于 RAG，后续使用)
# ============================================================
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# ============================================================
# 应用配置
# ============================================================
DEBUG=false
DATA_DIR=data

# ============================================================
# 本地持久化（SQLite）
# 路径默认 <项目根>/data/lifee.db，如需放别处改 LIFEE_DB_PATH
# ============================================================
LIFEE_DB_PATH=

# ============================================================
# 自家 Auth（替换 Supabase Auth）
# JWT_SECRET 必填：python -c "import secrets; print(secrets.token_hex(32))"
# ============================================================
JWT_SECRET=
JWT_TTL_DAYS=30

# ============================================================
# Resend 邮件发送（发 OTP 验证码）
# 注册 https://resend.com 拿 API key
# 未填时 OTP 会打印到日志（本地开发够用）
# 有自己域名后把 RESEND_FROM 改成 "LIFEE <noreply@your-domain.com>"
# ============================================================
RESEND_API_KEY=
RESEND_FROM=LIFEE <onboarding@resend.dev>

# ============================================================
# Cloudflare Turnstile（人机验证，防脚本刷）
# 获取地址: https://dash.cloudflare.com → Turnstile
# ============================================================
TURNSTILE_SITEKEY=1x00000000000000000000AA
TURNSTILE_SECRET=1x0000000000000000000000000000000AA
